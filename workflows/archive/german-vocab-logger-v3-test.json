      "parameters": {
        "jsCode": "const text = ($json.message?.text || \"\").trim();\nconst user_id = $json.message?.chat?.id;\n\nconst key = text\n  .toLowerCase()\n  .replace(/[’']/g, \"\")\n  .replace(/[^\\p{L}\\p{N}\\s-]+/gu, \"\")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\nreturn [{ json: { ...$json, input_text: text, user_id, key } }];"
      },

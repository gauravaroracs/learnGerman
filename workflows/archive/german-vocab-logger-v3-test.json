        "jsCode": "const row = $items('Get Row (by user_id + key)')[0].json;\nconst today = new Date().toISOString().slice(0,10);\nconst lookups = Number(row.lookups || 0) + 1;\n\nreturn [{\n  json: {\n    telegram_text: row.telegram_text || `${row.Word || row.word_or_phrase} (${row.POS || row.pos})\\nEN: ${row.Meaning_EN || row.meaning_en}\\nDE (einfach): ${row.Simple_DE || row.simple_de}\\nBeispiel: ${row.Example_DE || row.example_de}\\nEN: ${row.Example_EN || row.example_en}`,\n    row_number: row.rowNumber || row.row_number || row.__rowNumber || row.row || row.Row || \"\",\n    updates: { lookups, last_seen: today }\n  }\n}];"
      },
